# SPIDER Production Environment Variables
# Copy this to .env and fill in your values

# ─── Flask ───────────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_64_CHARS_MIN
FLASK_ENV=production

# ─── Database ────────────────────────────────────────────
# SQLite (default, fine for single server)
DATABASE_URL=sqlite:///spider.db

# PostgreSQL (recommended for production scale)
# DATABASE_URL=postgresql://spider_user:STRONG_PASSWORD@localhost:5432/spider_db

# ─── SSH Monitoring ──────────────────────────────────────
SSH_LOG_PATH=/var/log/auth.log
DEMO_MODE=false
BRUTE_FORCE_THRESHOLD=10
BRUTE_FORCE_WINDOW=60

# ─── Cowrie Honeypot ─────────────────────────────────────
COWRIE_LOG_PATH=/home/cowrie/cowrie/var/log/cowrie/cowrie.json

# ─── GeoIP ───────────────────────────────────────────────
GEOIP_CACHE_TTL=86400

# ─── WhatsApp (CallMeBot) ────────────────────────────────
WHATSAPP_NUMBER=8281762218
WHATSAPP_API_KEY=your_callmebot_api_key_here

# ─── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Email (SMTP) ────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=alerts@yourdomain.com

# ─── System Alert Thresholds ─────────────────────────────
CPU_ALERT_THRESHOLD=80
RAM_ALERT_THRESHOLD=85
DISK_ALERT_THRESHOLD=90
